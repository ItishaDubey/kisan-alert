# Meta WhatsApp
WHATSAPP_PHONE_NUMBER_ID=          # From Meta App Dashboard > WhatsApp > API Setup
WHATSAPP_BUSINESS_ACCOUNT_ID=      # From Meta App Dashboard > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=             # System user permanent token (never expires)
WHATSAPP_VERIFY_TOKEN=             # Any string you choose — used for webhook verification
WHATSAPP_APP_SECRET=               # From Meta App Dashboard > App Settings > Basic — used for payload signature verification
WHATSAPP_API_VERSION=v19.0

# Google Cloud
GCP_PROJECT_ID=                    # Your GCP project ID
GCP_REGION=asia-south1             # Mumbai — lowest latency for India
GOOGLE_APPLICATION_CREDENTIALS=   # Path to service account JSON (local dev only)

# Gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite-preview-06-17

# Google Maps
GOOGLE_MAPS_API_KEY=

# Firestore
FIRESTORE_COLLECTION_FARMERS=farmers
FIRESTORE_COLLECTION_SESSIONS=sessions
FIRESTORE_COLLECTION_CASES=crop_cases

# Vertex AI (for RAG)
VERTEX_AI_INDEX_ENDPOINT=          # Created after running scripts/seed_rag.py
VERTEX_AI_DEPLOYED_INDEX_ID=       # Created after running scripts/seed_rag.py
VERTEX_AI_LOCATION=us-central1     # Vertex AI Vector Search only in us-central1

# Cloud TTS output bucket (for serving OGG files to WhatsApp)
GCS_AUDIO_BUCKET=kisan-alert-audio

# Alert scheduler secret (Cloud Scheduler sends this header to authenticate)
SCHEDULER_SECRET=                  # Any strong random string
